<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Saved Recipes</title>
    <%= csrf_meta_tags %>
</head>

<body data-page="saved-recipes-index" style="background-color: #f2f2f7; color: #000000; padding: 16px; max-width: 600px; margin: 0 auto; min-height: 100vh; box-sizing: border-box; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
<div data-saved-recipes-container style="box-sizing: border-box;">
    <div style="display: flex; justify-content: flex-start; margin-bottom: 20px;">
        <a href="<%= new_recipe_search_path %>" style="display: inline-flex; align-items: center; gap: 8px; padding: 10px 16px; background-color: #ffffff; color: #007aff; text-decoration: none; border-radius: 12px; font-size: 16px; font-weight: 500; box-shadow: 0px 4px 12px rgba(0, 0, 0, 0.08); transition: all 0.2s ease;">
            <span>←</span> Back to Search
        </a>
    </div>
    
    <h1 style="font-size: 28px; font-weight: 700; margin-bottom: 24px; text-align: center;">My Saved Recipes</h1>
    
    <div style="display: flex; flex-direction: column; gap: 16px;">
        <% @saved_recipes.each do |recipe| %>
            <div style="background-color: #ffffff; border-radius: 16px; padding: 20px; box-shadow: 0px 4px 12px rgba(0, 0, 0, 0.08); display: flex; gap: 16px; align-items: flex-start;">
                <%= image_tag recipe.thumbnail, style: "width: 100px; height: 100px; border-radius: 12px; object-fit: cover; flex-shrink: 0;", alt: recipe.name %>
                <div style="flex: 1; display: flex; flex-direction: column; gap: 12px;">
                    <h3 style="font-size: 18px; font-weight: 600; color: #000000; margin: 0;"><%= recipe.name %></h3>
                    <%= button_to "Remove", saved_recipe_path(recipe), 
                                  method: :delete, 
                                  style: "align-self: flex-start; padding: 8px 16px; background-color: #ff3b30; color: white; border: none; border-radius: 12px; font-size: 15px; font-weight: 500; cursor: pointer; transition: all 0.2s ease;",
                                  form: { 
                                    data: { 
                                      turbo_confirm: "Remove this recipe?",
                                      turbo_method: :delete 
                                    } 
                                  } %>
                </div>
            </div>
        <% end %>
    </div>
    
    <% if @saved_recipes.empty? %>
        <div style="text-align: center; padding: 60px 20px; color: #8e8e93;">
            <p style="font-size: 17px; margin: 0;">No recipes saved yet.</p>
        </div>
    <% end %>
</div>

<style>
    body[data-page="saved-recipes-index"] {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    }
    
    body[data-page="saved-recipes-index"] a:hover {
        background-color: rgba(0, 122, 255, 0.1) !important;
    }
    
    body[data-page="saved-recipes-index"] a:active {
        transform: scale(0.98) !important;
    }
    
    body[data-page="saved-recipes-index"] button:active {
        transform: scale(0.98) !important;
        opacity: 0.8 !important;
    }
    
    body[data-page="saved-recipes-index"] input[type="submit"]:hover {
        background-color: #d70015 !important;
    }
</style>

<script>
(function() {
    'use strict';
    
    if (document.body.getAttribute('data-page') !== 'saved-recipes-index') return;
    const container = document.querySelector('[data-saved-recipes-container]');
    if (!container) return;
    
    const removeButtons = container.querySelectorAll('input[type="submit"][value="Remove"]');
    
    removeButtons.forEach(button => {
        const originalForm = button.closest('form');
        
        button.addEventListener('click', function(e) {
            button.style.opacity = '0.7';
            button.style.transform = 'scale(0.95)';
            
            setTimeout(() => {
                button.style.opacity = '';
                button.style.transform = '';
            }, 150);
        });
        
        if (originalForm) {
            originalForm.addEventListener('submit', function(e) {
                button.disabled = true;
                button.value = 'Removing...';
                button.style.opacity = '0.6';
            });
        }
    });
    
    const recipeCards = container.querySelectorAll('[style*="background-color: #ffffff"]');
    
    recipeCards.forEach((card, index) => {
        card.style.opacity = '0';
        card.style.transform = 'translateY(20px)';
        card.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
        
        setTimeout(() => {
            card.style.opacity = '1';
            card.style.transform = 'translateY(0)';
        }, index * 100);
    });
    
    const emptyState = container.querySelector('[style*="text-align: center"]');
    if (emptyState) {
        emptyState.style.opacity = '0';
        emptyState.style.transition = 'opacity 0.5s ease';
        
        setTimeout(() => {
            emptyState.style.opacity = '1';
        }, 300);
    }
    
    function cleanup() {
        removeButtons.forEach(button => {
            button.removeEventListener('click', arguments.callee);
            const form = button.closest('form');
            if (form) {
                form.removeEventListener('submit', arguments.callee);
            }
        });
    }
    
    window.addEventListener('beforeunload', cleanup);
    document.addEventListener('turbo:before-cache', cleanup);
    
})();
</script>
</body>
</html>