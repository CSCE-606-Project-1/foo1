<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recipe Results</title>
    <%= csrf_meta_tags %>
</head>

<body data-page="recipe-results-show" style="background-color: #f2f2f7; color: #000000; padding: 16px; max-width: 600px; margin: 0 auto; min-height: 100vh; display: flex; flex-direction: column; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; box-sizing: border-box;">
<div data-recipe-results-container style="box-sizing: border-box;">
    <h1 style="font-size: 28px; font-weight: 700; margin-bottom: 16px; text-align: center;">Recipe Results</h1>
    
    <div style="display: flex; justify-content: flex-start; margin-bottom: 16px;">
        <a href="<%= new_recipe_search_path %>" style="display: inline-flex; align-items: center; gap: 8px; padding: 10px 16px; background-color: #ffffff; color: #007aff; text-decoration: none; border-radius: 12px; font-size: 16px; font-weight: 500; box-shadow: 0px 4px 12px rgba(0, 0, 0, 0.08); transition: all 0.2s ease;">
            <span>←</span> Back to Search
        </a>
    </div>
    
    <div style="background-color: #ffffff; border-radius: 12px; padding: 16px; margin-bottom: 20px; box-shadow: 0px 4px 12px rgba(0, 0, 0, 0.08);">
        <strong style="color: #8e8e93; font-size: 14px; display: block; margin-bottom: 4px;">Searched Ingredients:</strong>
        <div style="font-size: 16px; color: #000000;">
            <% if @ingredient_list.present? %>
                <%= @ingredient_list.ingredients.pluck(:title).join(", ") %>
            <% else %>
                <%= @recipe_search.ingredients %>
            <% end %>
        </div>
    </div>
    
    <div id="recipe-card" style="background-color: #ffffff; border-radius: 16px; padding: 20px; margin-bottom: 20px; box-shadow: 0px 4px 12px rgba(0, 0, 0, 0.08); text-align: center; min-height: 300px; display: flex; flex-direction: column; justify-content: center; align-items: center;"></div>
    
    <div style="display: flex; justify-content: space-between; gap: 16px; margin-top: auto;">
        <button id="hate-btn" style="flex: 1; padding: 14px 20px; border: none; border-radius: 10px; font-size: 17px; font-weight: 600; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; transition: all 0.2s ease; background-color: #ff3b30; color: white;">
            <span>❌</span> Hate
        </button>
        <button id="like-btn" style="flex: 1; padding: 14px 20px; border: none; border-radius: 10px; font-size: 17px; font-weight: 600; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; transition: all 0.2s ease; background-color: #34c759; color: white;">
            <span>💚</span> Like
        </button>
    </div>
    
    <div style="text-align: center; margin-top: 12px; font-size: 14px; color: #8e8e93;">
        Use ← and → arrow keys to navigate
    </div>
    
    <div id="recipe-modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.5); z-index: 1000; padding: 16px;">
        <div style="background-color: #ffffff; border-radius: 16px; width: 100%; max-width: 600px; max-height: 90vh; overflow-y: auto; position: relative; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2); margin: 5vh auto;">
            <div style="padding: 16px; border-bottom: 1px solid #c6c6c8; display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; background-color: #ffffff; border-radius: 16px 16px 0 0; z-index: 10;">
                <h2 style="font-size: 20px; font-weight: 600;">Recipe Details</h2>
                <span id="modal-close" style="font-size: 24px; cursor: pointer; color: #8e8e93; width: 30px; height: 30px; display: flex; align-items: center; justify-content: center; border-radius: 50%;">&times;</span>
            </div>
            <div id="modal-content" style="padding: 16px;"></div>
        </div>
    </div>
    
    <div style="padding: 16px; border-top: 1px solid #c6c6c8; display: flex; justify-content: center; background-color: #ffffff; border-radius: 0 0 16px 16px; position: sticky; bottom: 0; margin-top: 20px;">
        <button id="save-recipe-btn" style="padding: 12px 24px; background-color: #007aff; color: white; border: none; border-radius: 10px; font-size: 17px; font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: 8px; transition: all 0.2s ease;">
            💾 Save Recipe
        </button>
    </div>

    <style>
        body[data-page="recipe-results-show"] {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }
        
        @keyframes modalAppear {
            from {
                opacity: 0;
                transform: scale(0.9);
            }
            to {
                opacity: 1;
                transform: scale(1);
            }
        }
        
        body[data-page="recipe-results-show"] a:hover {
            background-color: rgba(0, 122, 255, 0.1) !important;
        }
        
        body[data-page="recipe-results-show"] a:active {
            transform: scale(0.98) !important;
        }
        
        body[data-page="recipe-results-show"] button:active {
            transform: scale(0.98) !important;
            opacity: 0.8 !important;
        }
        
        body[data-page="recipe-results-show"] #modal-close:hover {
            background-color: #f2f2f7 !important;
        }
        
        body[data-page="recipe-results-show"] #save-recipe-btn:hover {
            background-color: #0056cc !important;
        }
        
        body[data-page="recipe-results-show"] #save-recipe-btn:disabled {
            background-color: #8e8e93 !important;
            cursor: not-allowed !important;
            transform: none !important;
        }
        
        body[data-page="recipe-results-show"] #recipe-modal > div {
            animation: modalAppear 0.3s ease;
        }
    </style>

    <script>
    (function() {
        'use strict';
        
        if (document.body.getAttribute('data-page') !== 'recipe-results-show') return;
        const container = document.querySelector('[data-recipe-results-container]');
        if (!container) return;
        
        const meals = <%= raw(@meals.to_json) %>;
        let currentIndex = 0;

        const recipeCard = container.querySelector("#recipe-card");
        const hateBtn = container.querySelector("#hate-btn");
        const likeBtn = container.querySelector("#like-btn");
        const modal = container.querySelector("#recipe-modal");
        const modalContent = container.querySelector("#modal-content");
        const modalClose = container.querySelector("#modal-close");
        const saveBtn = container.querySelector("#save-recipe-btn");

        function renderRecipe() {
            if (meals.length === 0) {
                recipeCard.innerHTML = `
                    <div style="text-align: center; padding: 40px 20px; color: #8e8e93;">
                        <p style="font-size: 16px; margin-bottom: 8px;">No recipes found.</p>
                        <p style="font-size: 16px; margin-bottom: 8px;">Try different ingredients.</p>
                    </div>
                `;
                hateBtn.style.display = "none";
                likeBtn.style.display = "none";
                return;
            }

            if (currentIndex >= meals.length) {
                recipeCard.innerHTML = `
                    <div style="text-align: center; padding: 40px 20px; color: #8e8e93;">
                        <p style="font-size: 16px; margin-bottom: 8px;">No more recipes available.</p>
                    </div>
                `;
                hateBtn.style.display = "none";
                likeBtn.style.display = "none";
                return;
            }

            const meal = meals[currentIndex];
            recipeCard.innerHTML = `
                <h2 style="font-size: 22px; font-weight: 600; margin-bottom: 12px;">${meal.strMeal}</h2>
                <img src="${meal.strMealThumb}" width="300" style="border-radius:12px; max-width: 100%; height: auto; margin-bottom: 12px;" />
                <p style="color: #8e8e93; font-size: 14px;">Meal ID: ${meal.idMeal}</p>
            `;
        }

        async function showModal(meal) {
            const response = await fetch(`https://www.themealdb.com/api/json/v1/1/lookup.php?i=${meal.idMeal}`);
            const data = await response.json();
            const details = data.meals[0];

            let ingredientsHtml = '';
            for (let i = 1; i <= 20; i++) {
                const ing = details["strIngredient" + i];
                const measure = details["strMeasure" + i];
                if (ing && ing.trim()) {
                    ingredientsHtml += `<li style="margin-bottom: 4px;">${ing} - ${measure}</li>`;
                }
            }

            modalContent.innerHTML = `
                <img src="${details.strMealThumb}" style="width: 100%; border-radius: 12px; margin-bottom: 16px;" />
                <div style="margin-bottom: 20px;">
                    <h3 style="font-size: 17px; font-weight: 600; margin-bottom: 8px; color: #000000;">About</h3>
                    <p style="font-size: 16px; line-height: 1.4; color: #000000;"><strong>Category:</strong> ${details.strCategory}</p>
                    <p style="font-size: 16px; line-height: 1.4; color: #000000;"><strong>Area:</strong> ${details.strArea}</p>
                </div>
                <div style="margin-bottom: 20px;">
                    <h3 style="font-size: 17px; font-weight: 600; margin-bottom: 8px; color: #000000;">Instructions</h3>
                    <p style="font-size: 16px; line-height: 1.4; color: #000000;">${details.strInstructions}</p>
                </div>
                <div style="margin-bottom: 20px;">
                    <h3 style="font-size: 17px; font-weight: 600; margin-bottom: 8px; color: #000000;">Ingredients</h3>
                    <ul style="font-size: 16px; line-height: 1.4; color: #000000; padding-left: 20px;">${ingredientsHtml}</ul>
                </div>
            `;
            modal.style.display = "block";
            setupSaveButton(meal);
        }

        function setupSaveButton(meal) {
            saveBtn.disabled = false;
            saveBtn.textContent = "💾 Save Recipe";
            saveBtn.style.backgroundColor = "";

            saveBtn.onclick = () => {
                saveBtn.disabled = true;
                saveBtn.textContent = "Saving...";

                fetch("/saved_recipes", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "X-CSRF-Token": document.querySelector('meta[name="csrf-token"]').content
                    },
                    body: JSON.stringify({
                        meal_id: meal.idMeal,
                        name: meal.strMeal,
                        thumbnail: meal.strMealThumb
                    })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        saveBtn.textContent = "✓ Saved!";
                        saveBtn.style.backgroundColor = "#34c759";

                        setTimeout(() => {
                            modal.style.display = "none";
                            currentIndex++;
                            renderRecipe();

                            if (currentIndex < meals.length) {
                                setupSaveButton(meals[currentIndex]);
                            }
                        }, 800);
                    } else {
                        saveBtn.textContent = "💾 Save Recipe";
                        saveBtn.disabled = false;
                        alert(data.message || "Failed to save recipe");
                    }
                })
                .catch(err => {
                    console.error(err);
                    saveBtn.textContent = "💾 Save Recipe";
                    saveBtn.disabled = false;
                    alert("Error saving recipe");
                });
            };
        }

        function closeModal() {
            modal.style.display = "none";
        }

        function handleHateClick() {
            currentIndex++;
            renderRecipe();
            if (currentIndex < meals.length) {
                setupSaveButton(meals[currentIndex]);
            }
        }

        function handleLikeClick() {
            showModal(meals[currentIndex]);
        }

        function handleModalClick(e) {
            if (e.target === modal) {
                closeModal();
            }
        }

        function handleKeydown(e) {
            if (modal.style.display === "block") {
                if (e.key === "Escape") {
                    closeModal();
                }
            } else {
                if (e.key === "ArrowLeft") {
                    currentIndex++;
                    renderRecipe();
                    if (currentIndex < meals.length) {
                        setupSaveButton(meals[currentIndex]);
                    }
                } else if (e.key === "ArrowRight") {
                    showModal(meals[currentIndex]);
                }
            }
        }

        // Add event listeners
        hateBtn.addEventListener("click", handleHateClick);
        likeBtn.addEventListener("click", handleLikeClick);
        modalClose.addEventListener("click", closeModal);
        window.addEventListener("click", handleModalClick);
        window.addEventListener("keydown", handleKeydown);

        function cleanup() {
            hateBtn.removeEventListener("click", handleHateClick);
            likeBtn.removeEventListener("click", handleLikeClick);
            modalClose.removeEventListener("click", closeModal);
            window.removeEventListener("click", handleModalClick);
            window.removeEventListener("keydown", handleKeydown);
        }

        window.addEventListener('beforeunload', cleanup);
        document.addEventListener('turbo:before-cache', cleanup);

        renderRecipe();
        if (meals.length > 0) {
            setupSaveButton(meals[0]);
        }

    })();
    </script>
</div>
</body>
</html>