<div data-page="recipe-search-form">
    <h1 style="font-size: 28px; font-weight: 700; margin-bottom: 24px; text-align: center;">Recipe Search</h1>
    
    <div style="background-color: #ffffff; border-radius: 16px; padding: 20px; box-shadow: 0px 4px 12px rgba(0, 0, 0, 0.08);">
        <%= form_with(model: @recipe_search, local: true, data: { turbo: false }) do |form| %>
            <% if @recipe_search.errors.any? %>
                <div style="background-color: rgba(255, 59, 48, 0.1); border: 1px solid #ff3b30; border-radius: 12px; padding: 16px; margin-bottom: 20px;">
                    <h2 style="color: #ff3b30; font-size: 17px; font-weight: 600; margin-bottom: 8px;">
                        <%= pluralize(@recipe_search.errors.count, "error") %> prohibited this recipe search from being saved:
                    </h2>
                    <ul style="padding-left: 20px;">
                        <% @recipe_search.errors.full_messages.each do |msg| %>
                            <li style="color: #ff3b30; font-size: 15px; margin-bottom: 4px;"><%= msg %></li>
                        <% end %>
                    </ul>
                </div>
            <% end %>
            
            <p style="color: #8e8e93; font-size: 15px; font-style: italic; margin-bottom: 20px; text-align: center; padding: 12px; background-color: rgba(142, 142, 147, 0.1); border-radius: 12px;">
                Enter ingredients manually <strong>or</strong> choose a saved list (leave the other blank).
            </p>
            
            <div style="margin-bottom: 24px;">
                <%= form.label :ingredients, "Enter ingredients (comma separated)", style: "display: block; font-size: 17px; font-weight: 600; margin-bottom: 8px; color: #000000;" %>
                <%= form.text_area :ingredients, rows: 3, style: "width: 100%; padding: 12px 16px; border: 1px solid #c6c6c8; border-radius: 12px; font-size: 17px; resize: vertical; min-height: 100px; transition: border-color 0.2s;", placeholder: "e.g., chicken, rice, tomatoes" %>
            </div>
            
            <div style="display: flex; align-items: center; text-align: center; margin: 20px 0; color: #8e8e93; font-size: 15px;">
                <span style="flex: 1; border-bottom: 1px solid #c6c6c8; margin-right: 16px;"></span>
                OR
                <span style="flex: 1; border-bottom: 1px solid #c6c6c8; margin-left: 16px;"></span>
            </div>
            
            <div style="margin-bottom: 24px;">
                <%= form.label :ingredient_list_id, "Choose an Ingredient List", style: "display: block; font-size: 17px; font-weight: 600; margin-bottom: 8px; color: #000000;" %>
                <%= form.collection_select :ingredient_list_id,
                                           @ingredient_lists,
                                           :id,
                                           :title,
                                           { include_blank: "Select a saved list..." },
                                           { style: "width: 100%; padding: 12px 16px; border: 1px solid #c6c6c8; border-radius: 12px; font-size: 17px; background-color: white; appearance: none; background-image: url('data:image/svg+xml;charset=US-ASCII,<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 4 5\"><path fill=\"%238e8e93\" d=\"M2 0L0 2h4zm0 5L0 3h4z\"/></svg>'); background-repeat: no-repeat; background-position: right 12px center; background-size: 12px; transition: border-color 0.2s;" } %>
            </div>
            
            <div>
                <%= form.submit "Search Recipes", style: "width: 100%; padding: 16px; background-color: #007aff; color: white; border: none; border-radius: 12px; font-size: 17px; font-weight: 600; cursor: pointer; transition: all 0.2s ease;" %>
            </div>
        <% end %>
    </div>
</div>

<style>
    div[data-page="recipe-search-form"] {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    }
    
    div[data-page="recipe-search-form"] textarea:focus,
    div[data-page="recipe-search-form"] select:focus {
        outline: none;
        border-color: #007aff !important;
    }
    
    div[data-page="recipe-search-form"] input[type="submit"]:active {
        transform: scale(0.98) !important;
        opacity: 0.8 !important;
    }
</style>

<script>
(function() {
    'use strict';
    
    const formContainer = document.querySelector('div[data-page="recipe-search-form"]');
    if (!formContainer) return;
    
    const ingredientsTextarea = formContainer.querySelector('#recipe_search_ingredients');
    const ingredientListSelect = formContainer.querySelector('#recipe_search_ingredient_list_id');
    
    function handleFieldChange() {
        if (ingredientsTextarea && ingredientListSelect) {
            if (ingredientsTextarea.value.trim() && ingredientListSelect.value) {
                ingredientListSelect.value = '';
            }
        }
    }
    
    if (ingredientsTextarea) {
        ingredientsTextarea.addEventListener('input', handleFieldChange);
    }
    
    if (ingredientListSelect) {
        ingredientListSelect.addEventListener('change', handleFieldChange);
    }
    
    const form = formContainer.querySelector('form');
    if (form) {
        form.addEventListener('submit', function(e) {
            const ingredientsValue = ingredientsTextarea ? ingredientsTextarea.value.trim() : '';
            const listValue = ingredientListSelect ? ingredientListSelect.value : '';
            
            if (!ingredientsValue && !listValue) {
                e.preventDefault();
                alert('Please enter ingredients or select an ingredient list.');
                return false;
            }
        });
    }
    
    function cleanup() {
        if (ingredientsTextarea) {
            ingredientsTextarea.removeEventListener('input', handleFieldChange);
        }
        if (ingredientListSelect) {
            ingredientListSelect.removeEventListener('change', handleFieldChange);
        }
        if (form) {
            form.removeEventListener('submit', arguments.callee);
        }
    }
    
    window.addEventListener('beforeunload', cleanup);
    document.addEventListener('turbo:before-cache', cleanup);
    
})();
</script>